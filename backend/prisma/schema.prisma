// tradeox — Neon PostgreSQL schema
// Synced with ../src/ stores & mock types (June 2026)
// Run from backend/: npm run db:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (mirror ../src/store + ../src/lib/mock types) ─────────────────────

enum RegistrationStep {
  registered
  profile_completed
  email_verified
  evaluation_started
}

enum ProfileTitle {
  Mr  @map("Mr.")
  Ms  @map("Ms.")
  Mrs @map("Mrs.")
  Dr  @map("Dr.")
}

enum CommChannel {
  whatsapp
  sms
  call
}

enum ThemeMode {
  light
  dark
}

enum TradingStyle {
  day
  swing
  longterm
  passive
}

enum ExperienceLevel {
  beginner
  intermediate
  advanced
}

enum DefaultOrderType {
  market
  limit
  stop
  stop_limit
}

enum AccountPlan {
  free_trial
  paid
}

enum AccountStatus {
  active
  failed
  passed
  paused
}

enum EvaluationStepType {
  STEP_1 @map("1-Step")
  STEP_2 @map("2-Step")
}

enum OrderSide {
  buy
  sell
}

enum OrderType {
  market
  limit
  stop
  stop_limit
}

enum OrderStatus {
  pending
  open
  filled
  partially_filled
  cancelled
  rejected
}

enum OrderTimeInForce {
  day
  gtc
  ioc
  fok
}

enum BasketSizeMode {
  contracts
  lots
}

enum Exchange {
  NSE
  BSE
  MCX
}

enum InstrumentCategory {
  index
  future
  equity
  commodity
  option
}

enum InstrumentBadge {
  INDEX
  FUT
  EQ
  MCX
  CE
  PE
}

enum OptionSide {
  CE
  PE
}

enum ReferralStatus {
  pending
  approved
  paid
}

enum PayoutStatus {
  processing
  completed
}

enum BillingStatus {
  paid
  pending
  failed
  refunded
}

enum FeedbackCategory {
  general
  bug
  feature
  billing
  other
}

enum FeedbackStatus {
  open
  in_review
  resolved
}

// ─── Auth & users ────────────────────────────────────────────────────────────

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  passwordHash         String?
  name                 String
  title                ProfileTitle?
  phone                String?
  avatar               String            @default("av1")
  currency             String            @default("INR")
  startingBalance      Decimal?          @db.Decimal(14, 2)
  registrationStep     RegistrationStep?
  onboardingComplete   Boolean           @default(false)
  emailVerifiedAt      DateTime?
  failedAttempts       Int               @default(0)
  lockedUntil          DateTime?
  pendingAffiliateCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences        UserPreferences?
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerificationToken[]
  affiliateProfile   AffiliateProfile?
  evaluationAccounts EvaluationAccount[]
  billingRecords     BillingRecord[]
  feedback           FeedbackSubmission[]
  watchlists         Watchlist[]
  killSwitchEvents   KillSwitchEvent[]

  referralsMade    Referral[]        @relation("ReferrerUser")
  referralsAsBuyer Referral[]        @relation("BuyerUser")
  payouts          AffiliatePayout[]

  @@index([registrationStep])
}

model UserPreferences {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ProfilePage — Personal / Preferences tabs
  nickname       String?
  theme          ThemeMode   @default(light)
  onboardingHelp Boolean     @default(false)
  commChannel    CommChannel @default(whatsapp)

  // mockUser.preferences + trading room defaults
  defaultOrderType  DefaultOrderType @default(market)
  confirmOrders     Boolean          @default(true)
  notifyOrderFilled Boolean          @default(true)
  notifyPriceAlerts Boolean          @default(true)
  notifyNews        Boolean          @default(false)

  // OnboardingPage (step 2–3) — persisted when API replaces mock flow
  tradingStyle       TradingStyle?
  experienceLevel    ExperienceLevel?
  onboardingSymbols  String[]         @default([])

  // evaluationAccountStore.activeAccountId
  activeAccountId String?

  // instrumentStore — per-user trading room UI state
  activeInstrumentId String  @default("eq-hdfcbank")
  activeWatchlistId  String?

  // ProfilePage — Daily Kill Switch
  killSwitchActive    Boolean   @default(false)
  killSwitchActivatedAt DateTime?

  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model KillSwitchEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingDate DateTime @db.Date
  activatedAt DateTime @default(now())

  @@unique([userId, tradingDate])
}

// ─── Affiliate / Refer & Earn ────────────────────────────────────────────────
// Commission: flat ₹500 per referral (REFERRAL_REWARD_AMOUNT in mockAffiliate.ts)

model AffiliateProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  seeded    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([code])
}

model Referral {
  id               String         @id @default(cuid())
  affiliateUserId  String
  affiliateUser    User           @relation("ReferrerUser", fields: [affiliateUserId], references: [id])
  buyerUserId      String?
  buyerUser        User?          @relation("BuyerUser", fields: [buyerUserId], references: [id])
  referredName     String
  referredEmail    String
  program          String
  orderAmount      Decimal        @db.Decimal(12, 2)
  commissionAmount Decimal        @db.Decimal(12, 2)
  status           ReferralStatus @default(pending)
  billingRecordId  String?
  billingRecord    BillingRecord? @relation(fields: [billingRecordId], references: [id])
  createdAt        DateTime       @default(now())

  @@index([affiliateUserId, createdAt])
  @@index([referredEmail])
}

model AffiliatePayout {
  id              String       @id @default(cuid())
  affiliateUserId String
  affiliateUser   User         @relation(fields: [affiliateUserId], references: [id])
  amount          Decimal      @db.Decimal(12, 2)
  status          PayoutStatus @default(processing)
  createdAt       DateTime     @default(now())

  @@index([affiliateUserId])
}

// ─── Evaluation programs & plans ─────────────────────────────────────────────
// mockAssessmentPlans.ts — mockTradingPrograms, mockEvaluationPlanTiers

model TradingProgram {
  id                           String   @id
  title                        String
  subtitle                     String
  stages                       String[]
  profitTarget                 String
  maximumLossLimit             String
  maximumDailyLossLimit        String
  requiredTradingDays          String
  minimumProfitableTradingDays String
  reward                       String
  active                       Boolean  @default(true)
}

model EvaluationPlanTier {
  id                           String  @id
  balance                      Decimal @db.Decimal(14, 2)
  evaluationFee                Decimal @db.Decimal(12, 2)
  originalFee                  Decimal @db.Decimal(12, 2)
  savings                      Decimal @db.Decimal(12, 2)
  popular                      Boolean @default(false)
  active                       Boolean @default(true)
  profitTarget                 String  @default("10%")
  maximumLossLimit             String  @default("10%")
  maximumDailyLossLimit        String  @default("5%")
  requiredTradingDays          String  @default("4 days")
  minimumProfitableTradingDays String  @default("2 days")
  reward                       String  @default("Up to 90% profit split")

  billingRecords BillingRecord[]
}

// ─── Evaluation accounts ─────────────────────────────────────────────────────
// mockEvaluationAccounts.ts — EvaluationAccount

model EvaluationAccount {
  id                   String             @id
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 AccountPlan
  status               AccountStatus      @default(active)
  stepType             EvaluationStepType
  accountSize          Decimal            @db.Decimal(14, 2)
  balance              Decimal            @db.Decimal(14, 2)
  equity               Decimal            @db.Decimal(14, 2)
  unrealizedPnL        Decimal            @db.Decimal(14, 2) @default(0)
  todayPnL             Decimal            @db.Decimal(14, 2) @default(0)
  freeMargin           Decimal            @db.Decimal(14, 2)
  marginUsed           Decimal            @db.Decimal(14, 2) @default(0)
  maxLoss              Decimal            @db.Decimal(14, 2)
  dailyMaxLoss         Decimal            @db.Decimal(14, 2)
  profitTarget         Decimal            @db.Decimal(14, 2)
  minTradingDays                 Int                @default(4)
  tradingDaysCompleted           Int                @default(0)
  minProfitableTradingDays       Int                @default(2)
  profitableTradingDaysCompleted Int                @default(0)
  reward                         String?
  rolloverProfit                 Decimal            @db.Decimal(14, 2) @default(0)
  labels               String[]           @default([])
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  orders         EvaluationOrder[]
  positions      EvaluationPosition[]
  baskets        TradingBasket[]
  equityCurve    EquityCurvePoint[]
  billingRecords BillingRecord[]
  tradingConfig  AccountTradingConfig?

  @@index([userId, status])
}

model EquityCurvePoint {
  id          String            @id @default(cuid())
  accountId   String
  account     EvaluationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ts          DateTime
  equity      Decimal           @db.Decimal(14, 2)
  balance     Decimal           @db.Decimal(14, 2)
  drawdownPct Decimal?          @db.Decimal(8, 4)

  @@index([accountId, ts])
}

// evaluationTradingStore.ts — EvaluationOrder

model EvaluationOrder {
  id              String            @id
  accountId       String
  account         EvaluationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId    String
  instrument      Instrument        @relation(fields: [instrumentId], references: [id])
  symbol          String
  name            String
  side            OrderSide
  type            OrderType
  status          OrderStatus
  timeInForce     OrderTimeInForce  @default(day)
  lots            Int
  filledLots      Int               @default(0)
  limitPrice      Decimal?          @db.Decimal(12, 4)
  stopPrice       Decimal?          @db.Decimal(12, 4)
  triggerPrice    Decimal?          @db.Decimal(12, 4)
  takeProfitPrice Decimal?          @db.Decimal(12, 4)
  stopLossPrice   Decimal?          @db.Decimal(12, 4)
  stopTriggered   Boolean           @default(false)
  filledPrice     Decimal?          @db.Decimal(12, 4)
  totalValue      Decimal           @db.Decimal(14, 2)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  filledAt        DateTime?

  @@index([accountId, status, createdAt])
  @@index([symbol, status])
}

// evaluationTradingStore.ts — EvaluationPosition

model EvaluationPosition {
  id            String            @id @default(cuid())
  accountId     String
  account       EvaluationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  String
  instrument    Instrument        @relation(fields: [instrumentId], references: [id])
  symbol        String
  name          String
  lots          Int
  avgEntry      Decimal           @db.Decimal(12, 4)
  ltp           Decimal           @db.Decimal(12, 4)
  unrealizedPnL Decimal           @db.Decimal(14, 2)
  openedAt      DateTime          @default(now())

  @@unique([accountId, instrumentId])
  @@index([accountId])
}

// evaluationTradingStore.ts — TradingBasket + AccountTradingConfig

model TradingBasket {
  id            String            @id @default(cuid())
  accountId     String
  account       EvaluationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name          String
  sortOrder     Int               @default(0)
  instrumentIds String[]          @default([])
  createdAt     DateTime          @default(now())

  @@index([accountId])
}

model AccountTradingConfig {
  id             String            @id @default(cuid())
  accountId      String            @unique
  account        EvaluationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activeBasketId String?
  basketSizeMode BasketSizeMode    @default(lots)
}

// ─── Instruments & market data ─────────────────────────────────────────────
// mockInstruments.ts — Instrument

model Instrument {
  id          String             @id
  symbol      String
  displayName String
  category    InstrumentCategory
  filterTags  String[]           @default([])
  badge       InstrumentBadge
  exchange    Exchange
  expiry      String?
  lotSize     Int                @default(1)
  tickSize    Decimal?           @db.Decimal(12, 4)
  lastPrice   Decimal            @db.Decimal(12, 4) @default(0)
  bid         Decimal            @db.Decimal(12, 4) @default(0)
  ask         Decimal            @db.Decimal(12, 4) @default(0)
  strike      Decimal?           @db.Decimal(12, 4)
  optionSide  OptionSide?
  underlying  String?
  commodityTag String?
  viewOnly    Boolean            @default(false)
  chartSymbol String
  isTradable  Boolean            @default(true)
  updatedAt   DateTime           @updatedAt

  orders    EvaluationOrder[]
  positions EvaluationPosition[]

  @@unique([symbol, exchange])
  @@index([symbol])
  @@index([category])
}

// mockQuotes.ts — portfolioStore.liveQuotes / useMockTicker

model MarketQuote {
  symbol         String   @id
  name           String
  price          Decimal  @db.Decimal(12, 4)
  open           Decimal  @db.Decimal(12, 4)
  high           Decimal  @db.Decimal(12, 4)
  low            Decimal  @db.Decimal(12, 4)
  close          Decimal  @db.Decimal(12, 4)
  previousClose  Decimal  @db.Decimal(12, 4)
  change         Decimal  @db.Decimal(12, 4)
  changePct      Decimal  @db.Decimal(8, 4)
  volume         BigInt
  avgVolume      BigInt
  marketCap      String?
  peRatio        Decimal? @db.Decimal(10, 2)
  week52High     Decimal  @db.Decimal(12, 4)
  week52Low      Decimal  @db.Decimal(12, 4)
  dividendYield  Decimal? @db.Decimal(8, 4)
  beta           Decimal? @db.Decimal(8, 4)
  lastUpdated    DateTime @default(now())
}

// mockCandles.ts — ChartPanel OHLCV

model MarketCandle {
  id       String   @id @default(cuid())
  symbol   String
  interval String
  time     DateTime
  open     Decimal  @db.Decimal(12, 4)
  high     Decimal  @db.Decimal(12, 4)
  low      Decimal  @db.Decimal(12, 4)
  close    Decimal  @db.Decimal(12, 4)
  volume   BigInt   @default(0)

  @@unique([symbol, interval, time])
  @@index([symbol, interval, time])
}

// ─── Watchlists ──────────────────────────────────────────────────────────────
// instrumentStore.ts — watchlists: Record<string, string[]>

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String          @default("Watchlist")
  sortOrder Int             @default(0)
  items     WatchlistItem[]
  createdAt DateTime        @default(now())

  @@index([userId])
}

model WatchlistItem {
  id           String    @id @default(cuid())
  watchlistId  String
  watchlist    Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  instrumentId String
  sortOrder    Int       @default(0)

  @@unique([watchlistId, instrumentId])
}

// ─── Billing & payments ──────────────────────────────────────────────────────
// billingStore.ts — BillingRecord (frontend field `date` → paidAt)

model BillingRecord {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  accountId         String?
  account           EvaluationAccount? @relation(fields: [accountId], references: [id])
  planId            String?
  plan              EvaluationPlanTier? @relation(fields: [planId], references: [id])
  program           String
  accountSize       Decimal            @db.Decimal(14, 2)
  amount            Decimal            @db.Decimal(12, 2)
  currency          String             @default("INR")
  status            BillingStatus      @default(paid)
  paymentMethod     String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  paidAt            DateTime           @default(now())

  referrals Referral[]

  @@index([userId, paidAt])
}

// ─── Support & content ───────────────────────────────────────────────────────
// mockContact.ts, mockFaq.ts

model FeedbackSubmission {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  category  FeedbackCategory
  message   String
  status    FeedbackStatus   @default(open)
  createdAt DateTime         @default(now())
}

model FaqCategory {
  id        String    @id @default(cuid())
  title     String
  sortOrder Int       @default(0)
  published Boolean   @default(true)
  items     FaqItem[]
}

model FaqItem {
  id         String       @id @default(cuid())
  categoryId String?
  category   FaqCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categorySlug String?
  question   String
  answer     String       @db.Text
  sortOrder  Int          @default(0)
  published  Boolean      @default(true)
}
